# TARS backend environment

# Core model. The local .env may use a real GLM key.
GLM_API_KEY=
GLM_BASE=https://api.z.ai/api/coding/paas/v4
TARS_MODEL=glm-5.1

# Optional alternatives.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
KIMI_API_KEY=

# 9Router OpenAI-compatible endpoint.
# Local desktop default: http://127.0.0.1:20128/v1
NINEROUTER_BASE=http://127.0.0.1:20128/v1
NINEROUTER_API_KEY=local
NINEROUTER_MODEL=cx/gpt-5.5-high

# Bridges.
YUME_URL=http://127.0.0.1:2223
KAMUI_URL=http://127.0.0.1:1338
VIDEOGEN_URL=http://127.0.0.1:4197

# Ports.
TARS_BACKEND_PORT=62026
TARS_DASHBOARD_PORT=62025
