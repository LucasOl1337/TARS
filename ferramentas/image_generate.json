{
  "id": "image_generate",
  "name": "Gerar Imagem",
  "description": "Gera uma imagem pelo VideoGen usando o motor de imagem roteado pelo 9router/GPT direto.",
  "category": "criação",
  "kind": "bridge",
  "provider": "videogen",
  "capabilities": ["imagem", "geração visual", "videogen", "9router"],
  "tags": ["image", "videogen", "9router", "gpt-direct"],
  "prompt_instruction": "Use quando o usuário pedir para criar, gerar, desenhar ou renderizar uma imagem. Envie um prompt visual claro; por padrão use backend='gpt-direct', size='1536x1024', model='cx/gpt-5.5-image', quality='auto', outputFormat='png' e force=true.",
  "parameters": {
    "type": "object",
    "properties": {
      "mode": { "type": "string", "enum": ["single"], "description": "modo compacto de uma imagem" },
      "backend": { "type": "string", "enum": ["gpt-direct", "grok-terminal"], "description": "backend de imagem do VideoGen" },
      "prompt": { "type": "string", "description": "descrição visual detalhada da imagem" },
      "style": { "type": "string", "description": "estilo visual opcional aplicado ao prompt" },
      "size": { "type": "string", "enum": ["1024x1024", "1024x1536", "1536x1024", "1024x1792", "1792x1024"], "description": "tamanho de saída" },
      "model": { "type": "string", "description": "modelo de imagem para gpt-direct" },
      "quality": { "type": "string", "enum": ["auto", "low", "medium", "high"], "description": "qualidade para gpt-direct" },
      "outputFormat": { "type": "string", "enum": ["png", "jpeg", "webp"], "description": "formato de saída" },
      "force": { "type": "boolean", "description": "força nova geração mesmo se houver cache" }
    },
    "required": ["prompt"]
  },
  "invoke": { "type": "bridge", "bridge": "videogen", "method": "POST", "endpoint": "/api/images/generate" }
}
